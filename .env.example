# Скопируйте в .env и при необходимости измените значения.
# Обязательно для Langfuse (сгенерируйте для продакшена):
#   openssl rand -base64 32  → NEXTAUTH_SECRET, SALT
#   openssl rand -hex 32     → ENCRYPTION_KEY

NEXTAUTH_SECRET=changeme_openssl_rand_base64_32
SALT=changeme_openssl_rand_base64_32
ENCRYPTION_KEY=changeme_openssl_rand_hex_32

# Ключи для Langfuse SDK (нужны сервисам, которые пишут трейсы/читают промпты)
# Получить в Langfuse UI: Project Settings → API Keys
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# Для контейнеров (hereyouare) — только внутренний адрес: http://langfuse-web:3000
# Не задавайте localhost:3100 — из контейнера Langfuse недоступен по localhost
# LANGFUSE_BASE_URL=http://langfuse-web:3000
# LANGFUSE_PROMPT_LABEL=production
# LANGFUSE_ENABLED=true

# Часовой пояс хоста — прокидывается во все контейнеры (логи, время в приложениях)
# Примеры: Europe/Moscow, Asia/Almaty, Europe/London
TZ=Asia/Almaty

# Модель Ollama для hereyouare (детекция). По имени выбирается промпт в Langfuse:
# qwen2.5vl:... → hereyouare.detect.qwen2_5vl,  qwen3vl:... → hereyouare.detect.qwen3vl
# OLLAMA_MODEL=qwen2.5vl:7b-q4_K_M

# Опционально (есть дефолты в docker-compose):
# REDIS_AUTH=myredissecret
# POSTGRES_PASSWORD=postgres
# CLICKHOUSE_PASSWORD=clickhouse
# MINIO_ROOT_USER=minio
# MINIO_ROOT_PASSWORD=miniosecret
